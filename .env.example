# ============================================
# Chunav Mitra - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values.
# NEVER commit your .env file to version control.

# Server
PORT=3000

# Google Gemini API Key
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_google_gemini_api_key_here

# CORS - Set to your production domain to restrict access
# Example: https://chunav-mitra.onrender.com
# Leave unset for localhost development
ALLOWED_ORIGIN=https://your-domain.onrender.com
